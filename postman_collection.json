{
  "info": {
    "name": "node-postgres-crud",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:3000" },
    { "key": "token", "value": "" }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/auth/register",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"user@example.com\",\n  \"password\": \"password123\"\n}"
            }
          }
        },
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "if (res.token) pm.collectionVariables.set('token', res.token);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/auth/login",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"user@example.com\",\n  \"password\": \"password123\"\n}"
            }
          }
        }
      ]
    },
    {
      "name": "Users",
      "item": [
        {
          "name": "Get All Users",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/users"
          }
        },
        {
          "name": "Get User by ID",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/users/1"
          }
        },
        {
          "name": "Create User",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/users",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"John Doe\",\n  \"email\": \"john@example.com\",\n  \"password\": \"secret123\"\n}"
            }
          }
        },
        {
          "name": "Update User",
          "request": {
            "method": "PUT",
            "url": "{{baseUrl}}/users/1",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Jane Doe\"\n}"
            }
          }
        },
        {
          "name": "Delete User",
          "request": {
            "method": "DELETE",
            "url": "{{baseUrl}}/users/1"
          }
        }
      ]
    },
    {
      "name": "Posts",
      "item": [
        {
          "name": "Get All Posts (Admin)",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/posts",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }]
          }
        },
        {
          "name": "Get Posts Paginated",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/posts/paginated?page=1&size=10",
              "query": [
                { "key": "page", "value": "1" },
                { "key": "size", "value": "10" }
              ]
            },
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }]
          }
        },
        {
          "name": "Get Post by ID",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/posts/1",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }]
          }
        },
        {
          "name": "Create Post",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/posts",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"My first post\",\n  \"content\": \"Hello world content here\",\n  \"tags\": [{ \"tagId\": 1 }]\n}"
            }
          }
        }
      ]
    },
    {
      "name": "Tags",
      "item": [
        {
          "name": "Create Tag",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/tags",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"technology\"\n}"
            }
          }
        },
        {
          "name": "Add Tag to Post",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/tags/1/posts/1"
          }
        }
      ]
    },
    {
      "name": "Movies",
      "item": [
        {
          "name": "Get Movies (Paginated)",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/movies?page=1&limit=10&sortBy=title&order=asc",
              "query": [
                { "key": "page", "value": "1" },
                { "key": "limit", "value": "10" },
                { "key": "sortBy", "value": "title" },
                { "key": "order", "value": "asc" },
                { "key": "genreId", "value": "1", "disabled": true }
              ]
            },
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }]
          }
        },
        {
          "name": "Search Movies",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/movies/search?title=inception",
              "query": [{ "key": "title", "value": "inception" }]
            },
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }]
          }
        },
        {
          "name": "Get Movie by ID",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/movies/1",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }]
          }
        },
        {
          "name": "Create Movie (Admin)",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/movies",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Interstellar\",\n  \"synopsis\": \"A team of explorers travel through a wormhole in space.\",\n  \"posterUrl\": \"https://example.com/poster.jpg\",\n  \"releaseYear\": \"2014-11-07\",\n  \"genres\": [{ \"genreId\": 1 }]\n}"
            }
          }
        },
        {
          "name": "Update Movie (Admin)",
          "request": {
            "method": "PATCH",
            "url": "{{baseUrl}}/movies/1",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Interstellar (Updated)\",\n  \"synopsis\": \"Updated synopsis.\"\n}"
            }
          }
        },
        {
          "name": "Delete Movie (Admin)",
          "request": {
            "method": "DELETE",
            "url": "{{baseUrl}}/movies/1",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }]
          }
        }
      ]
    },
    {
      "name": "Genres",
      "item": [
        {
          "name": "Get All Genres",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/genres",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }]
          }
        },
        {
          "name": "Get Genre by ID",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/genres/1",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }]
          }
        },
        {
          "name": "Create Genre (Admin)",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/genres",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Sci-Fi\"\n}"
            }
          }
        },
        {
          "name": "Update Genre (Admin)",
          "request": {
            "method": "PATCH",
            "url": "{{baseUrl}}/genres/1",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Science Fiction\"\n}"
            }
          }
        },
        {
          "name": "Delete Genre (Admin)",
          "request": {
            "method": "DELETE",
            "url": "{{baseUrl}}/genres/1",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }]
          }
        }
      ]
    },
    {
      "name": "Ratings",
      "item": [
        {
          "name": "Get Movie Ratings",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/ratings?movieId=1",
              "query": [{ "key": "movieId", "value": "1" }]
            },
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }]
          }
        },
        {
          "name": "Create Rating",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/ratings",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"movieId\": 1,\n  \"value\": 4\n}"
            }
          }
        },
        {
          "name": "Update Rating",
          "request": {
            "method": "PATCH",
            "url": "{{baseUrl}}/ratings/1",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"value\": 5\n}"
            }
          }
        },
        {
          "name": "Delete Rating",
          "request": {
            "method": "DELETE",
            "url": "{{baseUrl}}/ratings/1",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }]
          }
        }
      ]
    },
    {
      "name": "Reviews",
      "item": [
        {
          "name": "Get Movie Reviews",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/reviews?movieId=1",
              "query": [{ "key": "movieId", "value": "1" }]
            },
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }]
          }
        },
        {
          "name": "Create Review",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/reviews",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"movieId\": 1,\n  \"content\": \"An absolute masterpiece. The visuals and story are breathtaking.\"\n}"
            }
          }
        },
        {
          "name": "Update Review",
          "request": {
            "method": "PATCH",
            "url": "{{baseUrl}}/reviews/1",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"content\": \"Updated review content here.\"\n}"
            }
          }
        },
        {
          "name": "Delete Review",
          "request": {
            "method": "DELETE",
            "url": "{{baseUrl}}/reviews/1",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }]
          }
        }
      ]
    },
    {
      "name": "User Movies",
      "item": [
        {
          "name": "Get My List",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/user-movies",
              "query": [
                { "key": "status", "value": "WATCHLIST", "disabled": true }
              ]
            },
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }]
          }
        },
        {
          "name": "Add Movie to List",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/user-movies",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"movieId\": 1,\n  \"status\": \"WATCHLIST\"\n}"
            }
          }
        },
        {
          "name": "Update Movie Status",
          "request": {
            "method": "PATCH",
            "url": "{{baseUrl}}/user-movies/1",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"WATCHED\"\n}"
            }
          }
        },
        {
          "name": "Remove from List",
          "request": {
            "method": "DELETE",
            "url": "{{baseUrl}}/user-movies/1",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }]
          }
        }
      ]
    }
  ]
}
