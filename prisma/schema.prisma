generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        Int      @id @default(autoincrement())
  name      String
  email     String   @unique
  password  String
  createdAt DateTime @default(now())
  posts  Post[]
}

model Post {
  id Int @id @default(autoincrement())
  title String
  content String
  createdAt DateTime @default(now())
  userId Int
  user User @relation(fields: [userId], references: [id])
  tags PostTag[]
}

model Tag {
  id Int @id @default(autoincrement())
  name String
  posts PostTag[]
}

model PostTag {
  postId Int
  tagId Int 
  post Post @relation(fields:[postId], references: [id])
  tag Tag @relation(fields:[tagId],references:[id])
  @@id([postId,tagId])
}